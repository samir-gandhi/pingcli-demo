{
  "name": "Demo Password Policy",
  "description": "Standard password policy for demo environment",
  "enabled": true,
  "minCharacters": {
    "abcdefghijklmnopqrstuvwxyz": 1,
    "ABCDEFGHIJKLMNOPQRSTUVWXYZ": 1,
    "0123456789": 1
  },
  "length": {
    "min": 12,
    "max": 255
  },
  "history": {
    "count": 6,
    "retentionDays": 365
  },
  "lockout": {
    "failureCount": 5,
    "durationSeconds": 900
  }
}
